# =========================
# Build directories
# =========================
build/
cmake-build-*/
out/
bin/
obj/
lib/

# =========================
# CMake generated files
# =========================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake
Testing/

# =========================
# Compiled binaries / objects
# =========================
*.o
*.obj
*.a
*.so
*.so.*
*.dll
*.dylib
*.exe
*.out
*.app

# =========================
# Debug / profiling files
# =========================
*.dSYM/
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata
gmon.out
perf.data
perf.data.old
core
core.*

# =========================
# Logs and generated results
# =========================
logs/*
!logs/.gitkeep

results/*
!results/.gitkeep

experiments/output/*
!experiments/output/.gitkeep

# =========================
# Temporary simulation files
# =========================
*.tmp
*.temp
*.bak
*.old
*.swp
*.swo
*.lock

# =========================
# CSV / generated datasets
# =========================
*.csv
*.tsv
*.parquet
*.sqlite
*.db

# Keep example datasets if needed
!examples/**/*.csv
!config/**/*.csv

# =========================
# Editor / IDE files
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.iml

# =========================
# Linux / system files
# =========================
.DS_Store
Thumbs.db
.directory
.Trash-*

# =========================
# Python analysis environment
# If later you use Python for plotting/results
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.ipynb_checkpoints/

# =========================
# Documentation build outputs
# =========================
docs/_build/
site/

# =========================
# Package manager / dependency folders
# =========================
third_party/build/
vendor/build/

# =========================
# Local config overrides
# =========================
config/local.yaml
config/*.local.yaml
.env
.env.*